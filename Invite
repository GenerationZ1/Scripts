local pulse = TweenService:Create(copyButton,
    TweenInfo.new(0.6, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, 0, true, 0),
    {BackgroundColor3 = Color3.fromRGB(0, 180, 255)}
)
pulse:Play()
task.wait(0.6)
pulse:Cancel()
copyButton.BackgroundColor3 = Color3.fromRGB(0, 150, 230)

-- ===== SCHLIESSEN-FUNKTION (mit Slide-out nach rechts) =====
local function closeNotification(copyInvite)
    if isChecked and writefile then
        writefile(FILE_NAME, "true")
    end

    local slideOut = TweenService:Create(mainFrame,
        TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
        {Position = startPos}
    )
    slideOut:Play()
    slideOut.Completed:Connect(function()
        if copyInvite then
            if setclipboard then
                setclipboard(INVITE_LINK)
                copyButton.Text = "✅ Copied!"
                task.wait(0.8)
            else
                warn("setclipboard not available!")
            end
        end
        screenGui:Destroy()
    end)
end

