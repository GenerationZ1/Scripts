-- ===== ANIMATION (Slide-in von rechts mit Bounce) =====
local TweenService = game:GetService("TweenService")

local startPos = UDim2.new(1, 120, 0.5, -HEIGHT/2)
local endPos   = UDim2.new(1, -20 - WIDTH, 0.5, -HEIGHT/2)

mainFrame.Position = startPos

local slideIn = TweenService:Create(mainFrame,
    TweenInfo.new(0.9, Enum.EasingStyle.Back, Enum.EasingDirection.Out, 0, false, 0.5),
    {Position = endPos}
)
slideIn:Play()

-- Puls-Animation für Copy-Button
